<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:BoDraw="clr-namespace:BoDraw;assembly=BoDraw"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="BoDraw.MainWindow"
        Title="BoDraw">
    <DockPanel>
        <Panel x:Name="AnimationControls" DockPanel.Dock="Top" IsVisible="False">
            <StackPanel Orientation="Horizontal" Margin="6,0" Spacing="6">
                <Button x:Name="PlayPauseButton" Content="⏵"  MinWidth="32" HorizontalAlignment="Center"  Click="OnPlayPause" />
                <Button x:Name="StopButton"      Content="⏹"  MinWidth="32" HorizontalAlignment="Center"  Click="OnStop" />
                <Slider x:Name="TimeSlider" Width="300" Minimum="0" Maximum="1" ValueChanged="OnSliderChanged" />
            </StackPanel>
        </Panel>
        <BoDraw:BoDrawCanvas x:Name="Canvas" ClipToBounds="True" />
    </DockPanel>
</Window>
